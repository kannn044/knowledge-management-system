# ════════════════════════════════════════════════════════════════════
# KMS — Production environment for poc.mogh.go.th
# Copy to .env and fill in the real values before deploying.
# ════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_USER=kms_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=kms_db

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_char_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_min_32_char_random_refresh_secret

# ─── Internal service communication ─────────────────────────────────
INTERNAL_API_SECRET=CHANGE_ME_internal_secret

# ─── Frontend / CORS ─────────────────────────────────────────────────
# Browser origin (no subpath — CORS is origin-only)
FRONTEND_URL=https://poc.mogh.go.th

# ─── Google OAuth ────────────────────────────────────────────────────
# Add https://poc.mogh.go.th/kms/api/auth/google/callback to your
# Google Cloud Console → Credentials → Authorized redirect URIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://poc.mogh.go.th/kms/api/auth/google/callback

# ─── EmailJS ─────────────────────────────────────────────────────────
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID_VERIFY=your_template_id
EMAILJS_TEMPLATE_ID_APPROVE=your_template_id
EMAILJS_TEMPLATE_ID_RESET=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# ─── File uploads ────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ─── Vite build-time (only needed when building the frontend) ────────
# Used by: VITE_BASE_PATH=... npm run build
VITE_BASE_PATH=/kms/
VITE_API_URL=https://poc.mogh.go.th/kms
VITE_GOOGLE_CLIENT_ID=your_google_client_id
