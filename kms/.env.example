# ════════════════════════════════════════════════════════
# KMS — Environment Variables Example
# Copy this to .env and fill in real values
# NEVER commit .env to version control
# ════════════════════════════════════════════════════════

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=kms_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=kms_db

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Application ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/app/uploads

# ─── EmailJS ─────────────────────────────────────────────
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID_VERIFY=template_xxxxxxx
EMAILJS_TEMPLATE_ID_APPROVE=template_xxxxxxx
EMAILJS_TEMPLATE_ID_REJECT=template_xxxxxxx
EMAILJS_TEMPLATE_ID_RESET=template_xxxxxxx
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxx

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ─── Frontend Vite Vars ──────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_GOOGLE_CLIENT_ID=xxxxxxx.apps.googleusercontent.com

# ─── Internal service secret ─────────────────────────────
INTERNAL_API_SECRET=CHANGE_ME_INTERNAL_SECRET_MIN_32_CHARS

# ─── Sentry Error Tracking (optional, production only) ───────────
# SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx
# VITE_SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx
# VITE_APP_VERSION=1.0.0

# ─── Production overrides ────────────────────────────────
# FRONTEND_URL=https://kms.yourdomain.com
# GOOGLE_CALLBACK_URL=https://kms.yourdomain.com/api/auth/google/callback
# VITE_API_URL=https://kms.yourdomain.com
